{
  "description": "Harness engineering hooks — evaluation enforcement, progress recovery, test protection",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-check.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-init.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if the file being modified is a test file or harness state file. If the path contains '/tests/', '/__tests__/', 'feature_tests.json', or 'claude-progress.txt', respond with {\"decision\": \"block\", \"reason\": \"Cannot modify test/harness files — these are pre-generated by the Initializer and must not be changed by the coding or fixer agent.\"}. Otherwise respond with {\"decision\": \"allow\"}. The file path is: $ARGUMENTS",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/compact-handler.sh precompact",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/compact-handler.sh postcompact",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
