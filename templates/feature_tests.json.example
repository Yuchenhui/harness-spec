  "tasks": [
    {
      "id": "1.1",
      "description": "Create User model with password hashing",
      "spec_scenarios": [
        "Given a new user registration, When password is provided, Then it is stored as bcrypt hash",
        "Given User model, When queried by email, Then returns user object or None"
      ],
      "verification_level": "L2",
      "pre_generated_tests": true,
      "verification_commands": [
        "pytest tests/models/test_user.py -v"
      ],
      "passes": false,
      "last_evaluated": null,
      "evaluation_attempts": 0
    },
    {
      "id": "1.2",
      "description": "Add /auth/register endpoint",
      "spec_scenarios": [
        "Given valid email and password, When POST /auth/register, Then return 201 with user_id",
        "Given duplicate email, When POST /auth/register, Then return 409 Conflict"
      ],
      "verification_level": "L3",
      "pre_generated_tests": true,
      "verification_commands": [
        "pytest tests/api/test_auth.py::test_register_success -v",
        "pytest tests/api/test_auth.py::test_register_duplicate -v"
      ],
      "setup_commands": [
        "python -m uvicorn app.main:app --port 8000 &",
        "sleep 3"
      ],
      "teardown_commands": [
        "kill %1 2>/dev/null || true"
      ],
      "passes": false,
      "last_evaluated": null,
      "evaluation_attempts": 0
    },
    {
      "id": "2.1",
      "description": "Add login page with form validation",
      "spec_scenarios": [
        "Given login page, When valid credentials submitted, Then redirect to dashboard",
        "Given login page, When invalid password, Then show error message"
      ],
      "verification_level": "L4",
      "browser_verification": {
        "start_url": "http://localhost:3000/login",
        "scenarios": [
          {
            "description": "Successful login redirects to dashboard",
            "steps": [
              "Navigate to http://localhost:3000/login",
              "Type 'test@example.com' into email field",
              "Type 'SecurePass123!' into password field",
              "Click the login button",
              "Verify URL changed to /dashboard",
              "Take screenshot"
            ]
          },
          {
            "description": "Invalid password shows error",
            "steps": [
              "Navigate to http://localhost:3000/login",
              "Type 'test@example.com' into email field",
              "Type 'wrongpassword' into password field",
              "Click the login button",
              "Verify error message is visible",
              "Take screenshot"
            ]
          }
        ]
      },
      "setup_commands": [
        "npm run dev &",
        "sleep 5"
      ],
      "teardown_commands": [
        "kill %1 2>/dev/null || true"
      ],
      "passes": false,
