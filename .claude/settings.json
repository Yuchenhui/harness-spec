{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "Bash(npx vitest *)",
      "Bash(node bin/*)",
      "Bash(git *)",
      "Read(**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p = JSON.parse(process.argv[1]).tool_input?.file_path || ''; if (/\\/(tests|__tests__)\\//.test(p) || /feature_tests\\.json$/.test(p) || /claude-progress\\.txt$/.test(p)) { process.stderr.write('BLOCKED: Cannot modify test/harness files: ' + p); process.exit(2); }\" \"$CLAUDE_TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-check.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-init.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-notify.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
